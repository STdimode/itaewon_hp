@{
    string layoutPath = "/UserData/itaewonmc/Layouts/itaewonmc_Layout";
    string cssFile = layoutPath + "/Contents/Main_v1.css";
    string jsFile = layoutPath + "/Scripts/Main_v1.js";
    // 로컬 전환용 주석 (필요 시 해제)
    // string localFontCss = layoutPath + "/Contents/fonts.css";
