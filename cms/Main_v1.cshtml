<div class="cms-content-root">
    <!-- ━━━ HEADER ━━━ -->
    <header class="cms-header">
        <div class="cms-container cms-header-inner">
            <!-- logo -->
            <div class="cms-logo-wrap">
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                    <path d="M11 2C7 2 3 6 3 11c0 4 2 7 4 8.5C8 20 10 20 11 20c1 0 3 0 4-0.5 2-1.5 4-4.5 4-8.5C19 6 15 2 11 2z" fill="#2eb872"/>
                    <path d="M11 5v13M7 9c2 1 4 2 7 5" stroke="white" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                <span class="cms-logo-text">이태원교회</span>
            </div>
            <!-- nav -->
            <nav class="cms-nav">
                <a href="#" class="cms-nav-link">교회소개</a>
                <a href="#" class="cms-nav-link">새가족안내</a>
                <a href="#" class="cms-nav-link">다음세대(교회학교)</a>
                <a href="#" class="cms-nav-link">갈렙청년부</a>
                <a href="#" class="cms-nav-link">인터넷방송</a>
                <a href="#" class="cms-nav-link">Mission 2030</a>
                <a href="#" class="cms-nav-link">교회소식</a>
            </nav>
            <!-- hamburger -->
            <button class="cms-hamburger">
                <svg width="22" height="16" viewBox="0 0 22 16" fill="none" stroke="white" stroke-width="2" stroke-linecap="round">
                    <line x1="1" y1="1" x2="21" y2="1"/>
                    <line x1="1" y1="8" x2="21" y2="8"/>
                    <line x1="1" y1="15" x2="21" y2="15"/>
                </svg>
            </button>
        </div>
    </header>

    <!-- ━━━ HERO ━━━ -->
    <section class="cms-hero">
        <!-- Background image -->
        <div class="cms-hero-bg" style="background-image: url('/UserData/itaewonmc/Layouts/itaewonmc_Layout/images/asset_1.png');"></div>
        <!-- dots -->
        <div class="cms-hero-dots">
            <button class="cms-hero-dot" style="width: 28px; background: white;"></button>
        </div>
